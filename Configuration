sudo apt install fuse-overlayfs

mkdir -p /media/nathandrake/SDCard/DistroBox/Volumes
mkdir -p /media/nathandrake/SDCard/DistroBox/Storage

# On Terminal:
curl -s https://raw.githubusercontent.com/89luca89/distrobox/main/install | sh -s -- --prefix /media/$USER/SDCard/DistroBox

TO BASHRC:
[ -d /media/$USER/SDCard/DistroBox ] && {
  export PATH=/media/$USER/SDCard/DistroBox/bin:$PATH
  xhost +si:localuser:$USER
  }

# Setup subuid/subgid
sudo touch /etc/subuid
sudo touch /etc/subgid
sudo chmod 664 /etc/subuid /etc/subgid

sudo usermod --add-subuids 10000-75535 $USER 
sudo usermod --add-subgids 10000-75535 $USER

sudo nano /etc/containers/storage.conf

[storage]
graphroot = "/media/$USER/SDCard/DistroBox/Volumes"
runroot = "/media/$USER/SDCard/DistroBox/Storage"
driver = "overlay"
[storage.options.overlay]
mount_program = "/usr/bin/fuse-overlayfs"
mountopt = "nodev,index=off"

That's all folks!
